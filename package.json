{
  "name": "obsidian-frontmatter-date-manager",
  "version": "1.0.1",
  "description": "Automatically update created and modified dates in frontmatter when editing notes.",
  "main": "main.js",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
    "format:write": "prettier --write \"**/*.{ts,json}\"",
    "format:check": "prettier --list-different \"**/*.{ts,json}\"",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [],
  "author": "SmetDenis",
  "license": "MIT",
  "devDependencies": {
    "@eslint/js": "9.30.1",
    "@eslint/json": "0.14.0",
    "@types/node": "^22.19.19",
    "browserslist": "^4.28.2",
    "chokidar": "^5.0.0",
    "esbuild": "0.28.0",
    "esbuild-copy-static-files": "^0.1.0",
    "esbuild-plugin-copy": "^2.1.1",
    "esbuild-plugin-replace": "^1.4.0",
    "eslint-plugin-obsidianmd": "0.3.0",
    "fs-jetpack": "^5.1.0",
    "globals": "14.0.0",
    "jiti": "2.7.0",
    "lightningcss": "^1.32.0",
    "obsidian": "~1.12.3",
    "prettier": "3.8.3",
    "tslib": "2.8.1",
    "typescript": "6.0.3",
    "typescript-eslint": "8.60.1",
    "vitest": "^4.1.8"
  },
  "dependencies": {
    "@date-fns/tz": "^1.5.0",
    "date-fns": "4.4.0",
    "js-sha256": "^0.11.1",
    "picomatch": "^4.0.4"
  }
}
