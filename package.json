{
  "name": "obsidian-frontmatter-date-manager",
  "version": "1.0.0",
  "description": "Automatically update created and modified dates in frontmatter when editing notes.",
  "main": "main.js",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
    "format:write": "prettier --write \"**/*.{ts,json}\"",
    "format:check": "prettier --list-different \"**/*.{ts,json}\"",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [],
  "author": "SmetDenis",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^22.0.0",
    "browserslist": "^4.28.2",
    "builtin-modules": "5.1.0",
    "chokidar": "^5.0.0",
    "dotenv": "^17.4.1",
    "esbuild": "0.28.0",
    "esbuild-copy-static-files": "^0.1.0",
    "esbuild-plugin-copy": "^2.1.1",
    "esbuild-plugin-replace": "^1.4.0",
    "fs-jetpack": "^5.1.0",
    "lightningcss": "^1.32.0",
    "obsidian": "^1.12.3",
    "prettier": "3.8.2",
    "tslib": "2.8.1",
    "typescript": "6.0.2",
    "vitest": "^4.1.4"
  },
  "dependencies": {
    "@date-fns/tz": "^1.4.1",
    "date-fns": "4.1.0",
    "js-sha256": "^0.11.1",
    "picomatch": "^4.0.4"
  }
}
