{
  "compilerOptions": {
    "inlineSourceMap": true,
    "inlineSources": true,
    "module": "ESNext",
    "target": "ES2018",
    "allowJs": true,
    "moduleResolution": "bundler",
    "importHelpers": true,
    "strict": true,
    "isolatedModules": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedIndexedAccess": true,
    "types": ["node"],
    "lib": ["dom", "es2018"]
  },
  "include": ["**/*.ts"],
  "exclude": [
    "src/__tests__/**",
    "src/__mocks__/**",
    "vitest.config.ts",
    "tmp/**",
    "e2e/**"
  ]
}
