{
  "compilerOptions": {
    "inlineSourceMap": true,
    "inlineSources": true,
    "module": "ESNext",
    "target": "ES2018",
    "allowJs": true,
    "noImplicitAny": true,
    "moduleResolution": "bundler",
    "importHelpers": true,
    "strict": true,
    "types": ["node"],
    "lib": ["dom", "es2018"]
  },
  "include": ["**/*.ts"],
  "exclude": ["src/__tests__/**", "src/__mocks__/**", "vitest.config.ts"]
}
